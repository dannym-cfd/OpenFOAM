FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      alphat;
}

dimensions      [1 -1 -1 0 0 0 0];

internalField   uniform 6.19e-4;

boundaryField
{
    "missile_zone.*"
    {
        type            compressible::alphatJayatillekeWallFunction;
        Prt             0.85;
        value           uniform 0;
    }

    farfield_inflow
    {
        type            calculated;
        value           uniform 6.19e-4;
    }

    farfield_outflow
    {
        type            zeroGradient;//calculated;
        //value           //uniform 6.19e-4;
    }

    sides
    {
        type            calculated;
        value           uniform 6.19e-4;
    }
}
