FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

castellatedMesh true;
snap            true;
addLayers       true;

geometry
{
    missile
    {
        type triSurfaceMesh;
        file "missile.stl";
        name missile;
    }

//  nozzle
//  {
//      type triSurfaceMesh;
//      file "nozzle.stl";
//      name nozzle;
//  }

    refinementCone
    {
        type    searchableCylinder;
        point1  (0 0 0.45);
        point2  (0 0 -1.2);
        radius  0.45;
    }

    nearBodyBox
    {
        type searchableBox;
        min  (-0.25 -0.25 0.20);
        max  ( 0.25  0.25 0.45);
    }

    refinementBox
    {
        type box;
        min (-0.5 -0.5 -2.0);
        max ( 0.5  0.5  2.0);
    }
}

castellatedMeshControls
{
    maxLocalCells       2000000;
    maxGlobalCells      20000000;
    minRefinementCells  10;
    maxLoadUnbalance    0.10;
    nCellsBetweenLevels 3;

    features
    (
        { file "missile.eMesh"; level 9; }
//      { file "nozzle.eMesh"; level 7; }
    );

    refinementSurfaces
    {
        missile
        {
            level (8 9);
            patchInfo { type wall; }
        }

//      nozzle
//      {
//          level (6 7);
//          patchInfo { type patch; }
//      }
    }

    refinementRegions
    {
        refinementBox
        {
            mode    inside;
            levels  ((1 3));
        }

        refinementCone
        {
            mode    inside;
            levels  ((1E15 5));
        }

        nearBodyBox
        {
            mode    inside;
            levels  ((1E15 5));
        }
    }

    resolveFeatureAngle     25;
    locationInMesh          (0 0 3);
    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch            5;
    tolerance               1.0;
    nSolveIter              300;
    nRelaxIter              5;
    nFeatureSnapIter        20;
    implicitFeatureSnap     false;
    explicitFeatureSnap     true;
    multiRegionFeatureSnap  false;
}

addLayersControls
{
    relativeSizes           true;
    layers
    {
        "missile.*" { nSurfaceLayers 3; }
    }
    expansionRatio          1.2;
    finalLayerThickness     0.2;
    minThickness            0.02;

    nGrow                   0;
    featureAngle            180;

    maxFaceThicknessRatio   0.5;
    maxThicknessToMedialRatio 0.15;
    minMedianAxisAngle      150;

    nSmoothSurfaceNormals   20;
    nSmoothNormals          20;
    nSmoothThickness        10;

    nRelaxIter              5;
    nRelaxedIter            20;
    nLayerIter              50;
    nBufferCellsNoExtrude   1;
}

meshQualityControls
{
    maxNonOrtho             70;
    maxBoundarySkewness     20;
    maxInternalSkewness     4;
    maxConcave              80;
    minVol                  1e-30;
    minTwist                0.001;
    minDeterminant          0.001;
    minFaceWeight           0.02;
    minVolRatio             0.01;
    minTetQuality           1e-30;
    minArea                 -1;
    nSmoothScale            4;
    errorReduction          0.75;

    relaxed
    {
        maxNonOrtho         80;
        maxBoundarySkewness 25;
        maxInternalSkewness 8;
        maxConcave          80;
        minVol              1e-15;
        minTwist            0.0001;
        minDeterminant      0.0001;
        minFaceWeight       0.01;
        minVolRatio         0.001;
        minTetQuality       1e-30;
        minArea             -1;
    }
}

mergeTolerance 1e-6;
