    type            buoyancy;
    active          yes;
    selectionMode   all;
}
*/
rampVelocity
{
    type                velocityConstraint;
    active              yes;
    velocityConstraintCoeffs
    {
        selectionMode   all;
        field           U;
        timeFunction    linearRamp;
        ramp
        {
            start       0;
            duration    400;
            startValue  0;
            endValue    1;
        }
        targetVelocity  (0 0 -350);
    }
}
