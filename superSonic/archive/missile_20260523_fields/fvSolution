FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}

solvers
{
    "rho.*"
    {
        solver          diagonal;
    }

    "p.*"
    {
        solver          amgx;
        tolerance       1e-7;
        relTol          0.01;

        amgx
        {
            dict    Cfg;
        }
    }

    U
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0.1;
        maxIter         50;
    }

    UFinal
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0;
        maxIter         50;
    }

    e
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0.01;
        maxIter         100;
    }

    eFinal
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0;
        maxIter         100;
    }

    "(k|omega|alphat)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0.1;
        maxIter         50;
    }

    "(k|omega|alphat)Final"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0;
        maxIter         50;
    }

    Phi
    {
        solver              GAMG;
        smoother            GaussSeidel;
        tolerance           1e-7;
        relTol              0.001;
        nPreSweeps          0;
        nPostSweeps         2;
        cacheAgglomeration  true;
        agglomerator        faceAreaPair;
        nCellsInCoarsestLevel 100;
        mergeLevels         1;
    }
}

SIMPLE
{
    transonic               yes;
    nNonOrthogonalCorrectors    2;

    residualControl
    {
        p       1e-5;
        U       1e-5;
        e       1e-5;
        k       1e-5;
        omega   1e-5;
    }
}

relaxationFactors
{
    fields
    {
        p               0.15;
        rho             0.02;
    }
    equations
    {
        U               0.2;
        e               0.05;
        k               0.05;
        omega           0.05;
    }
}
